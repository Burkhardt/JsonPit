@startuml JsonPit-ClassDiagram
' Release: 3.7.7

title JsonPit Class Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam DiagramFontName "Casual"
skinparam DiagramFontSize 36
skinparam ClassFontName "Casual"
skinparam ClassFontSize 36
skinparam ClassAttributeIconSize 10
skinparam ClassAttributeFontName Casual
skinparam ClassAttributeFontColor #053583
skinparam ClassAttributeFontWeight normal
skinparam ClassAttributeFontSize 12
skinparam ClassMethodFontName "Casual"
skinparam ClassMethodFontSize 12
skinparam ClassMethodFontWeight 500
skinparam ClassAttributeFontStyle normal
skinparam ClassBorderColor #0f766e
skinparam ClassBackgroundColor #ccfbf1
skinparam ClassFontColor #111827
skinparam EnumBorderColor #b45309
skinparam EnumBackgroundColor #fef3c7
skinparam EnumFontColor #7c2d12
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #d4b106
skinparam ArrowColor #9b2c2c
skinparam ArrowFontColor #374151
skinparam ArrowFontName "Casual"

show circle

package "JsonPit" {
	class "<size:18>ItemsBase</size>" as ItemsBase {
		+Key : string
		+ItemsBase(key : string = null)
	}

	class "<size:18>JsonPitBase</size>" as JsonPitBase {
		+{static} Version : string
		+{static} ConfigDefaultDir : RaiPath
		+ReadOnly : bool
		+Backup : bool
		+ChangesDir : RaiPath
		+JsonFile : PitFile
		+RunningOnMaster() : bool
		+ProcessFlag() : ProcessFlagFile
		+MasterFlag() : MasterFlagFile
		+MasterUpdatesAvailable() : bool
		+FileHasChangedOnDisk() : bool
		+ForeignChangesAvailable() : bool
		+GetFileChanged() : DateTimeOffset
		+GetMemChanged() : DateTimeOffset
	}

	class "<size:18>TimestampedValue</size>" as TimestampedValue {
		+Time : DateTimeOffset
		+Value : string
		+ToString() : string
	}

	class "<size:18>MasterFlagFile</size>" as MasterFlagFile {
		+Originator : string
		+Time : DateTimeOffset
		+Save(backup : bool = false) : void
		+Update(time : DateTimeOffset? = null, originator : string = null) : TimestampedValue
		+{static} FileName(changeDir : RaiPath, name : string) : string
	}

	class "<size:18>ProcessFlagFile</size>" as ProcessFlagFile {
		+Process : string
		+{static} CurrentProcessId() : string
		+Update(time : DateTimeOffset? = null, process : string = null) : TimestampedValue
	}

	class "<size:18>PitFile</size>" as PitFile {
		+{static} SupportedExtensions : string[]
		+GetAllFiles(pitFolder : RaiPath, excludeCanonicalFile : bool = false) : IEnumerable<string>
	}

	class "<size:18>PitItem</size>" as PitItem {
		+Id : string
		+Modified : DateTimeOffset
		+Deleted : bool
		+Note : string
		+SetProperty(objectAsJsonString : string) : bool
		+SetProperty(obj : object) : void
		+DeleteProperty(propertyName : string) : void
		+Delete(by : string = null, backDate100 : bool = true) : bool
		+Extend(json : string) : bool
		+ExtendWith(obj : JObject) : bool
		+ExtendWith(arr : JArray) : bool
		+Valid() : bool
		+Validate() : void
		+Invalidate() : void
	}

	class "<size:18>PitItemExtensions</size> Ⓢ" as PitItemExtensions {
		+{static} Equals(x : PitItem, y : PitItem) : bool
		+{static} dtSharp : long
		+{static} isLike(dto1 : DateTimeOffset, dto2 : DateTimeOffset) : bool
		+{static} aligned(dto1 : DateTimeOffset, dto2 : DateTimeOffset) : DateTimeOffset
	}

	class "<size:18>PitItems</size>" as PitItems {
		+History : ImmutableList<PitItem>
		+Items : ImmutableList<PitItem>
		+MaxCount : int
		+Count : int
		+{static} Create(key : string, maxCount : int = 5) : PitItems
		+Push(item : PitItem) : PitItems
		+ProjectState(at : DateTimeOffset? = null, withDeleted : bool = false) : PitItem
		+Peek(timestamp : DateTimeOffset? = null) : PitItem
		+Get(timestamp : DateTimeOffset? = null) : JObject
	}

	class "<size:18>Pit</size>" as Pit {
		+HistoricItems : ConcurrentDictionary<string, PitItems>
		+Keys : ICollection<string>
		+DefaultMaxCount : int
		+Subscriber : string
		+PitItem : PitItem
		+ItemProperty : dynamic
		+this[key : string] : PitItem
		+ContainsKey(key : string) : bool
		+Contains(itemId : string, withDeleted : bool = false) : bool
		+Invalid() : bool
		+GetLastestItemChanged() : DateTimeOffset
		+Add(item : PitItem) : bool
		+Add(jsonObject : string) : bool
		+AddItems(items : IEnumerable<PitItem>) : bool
		+AddItems(jsonArray : string) : bool
		+Delete(itemId : string, by : string = null, backDate : bool = true) : bool
		+Get(key : string, withDeleted : bool = false) : JObject
		+GetAt(key : string, timestamp : DateTimeOffset, withDeleted : bool = false) : PitItem
		+AllUndeleted() : IEnumerable<JObject>
		+AllUndeletedDynamic() : IEnumerable<dynamic>
		+ValuesOverTime(oName : string, pName : string) : IEnumerable<KeyValuePair<DateTimeOffset, JToken>>
		+ValueListsOverTime(oName : string, pName : string) : IEnumerable<KeyValuePair<DateTimeOffset, List<JToken>>>
		+ExportJson(exportFilePath : RaiPath, at : DateTimeOffset? = null, pretty : bool = true) : void
		+Load(undercover : bool = false) : void
		+Save(backup : bool? = null, force : bool = false) : void
		+CreateChangeFile(item : PitItem, machineName : string = null) : void
		+MergeChanges() : void
		+MergeIntoHistory(changeItems : PitItems) : void
		+Reload() : bool
	}

	class "<size:18>Item</size>" as Item {
		+Id : string
		+Modified : DateTimeOffset
		+Deleted : bool
		+Note : string
		+Changed() : DateTimeOffset
		+Delete(by : string = null, backDate100 : bool = true) : bool
		+Valid() : bool
		+Validate() : void
		+Invalidate() : void
		+Matches(x : Item) : bool
		+Matches(se : SearchExpression) : bool
		+Matches(filter : string, comp : Compare = Compare.ByProperty) : bool
		+Clone<T>() : T
		+Clone() : dynamic
		+Merge(second : Item) : void
	}

	enum "<size:18>Compare</size>" as Compare << (E,#f59e0b) >> {
		JSON
		ByProperty
	}
}

class "JObject" as JObject <<external Newtonsoft>>
class "JArray" as JArray <<external Newtonsoft>>
class "JToken" as JToken <<external Newtonsoft>>
class "TextFile" as TextFile <<external OsLib>>
class "CanonicalFile" as CanonicalFile <<external OsLib>>
class "RaiPath" as RaiPath <<external OsLib>>
class "SearchExpression" as SearchExpression <<external RaiUtils>>

ItemsBase <|-- PitItems
JsonPitBase <|-- Pit
TextFile <|-- MasterFlagFile
MasterFlagFile <|-- ProcessFlagFile
CanonicalFile <|-- PitFile
JObject <|-- PitItem

JsonPitBase --> PitFile : owns
JsonPitBase --> ProcessFlagFile : uses
JsonPitBase --> MasterFlagFile : uses
PitItems --> PitItem : history
Pit --> PitItems : stores
Pit --> PitItem : adds and retrieves
Pit --> JArray : imports and exports
PitItemExtensions ..> PitItem : compares
PitItem ..> JArray : extends from
Item ..> SearchExpression : filters with
Item ..> Compare : comparison mode

class "Legend<size:10>ⓈⒶⓅ</size>" as LegendSample {
	+{static} staticMethod() : void
	-{static} staticProperty : string
	==
	~<i>Note on class markers :</i>
	<size:10>Ⓢ</size>tatic
	<size:10>Ⓐ</size>bstract
	Ⓟartial
	--
	- privateField : string
	+ publicField : string
	# protectedField : string
	~ internalField : string
	--
	- privateMethod() : void
	+ publicMethod() : void
	# protectedMethod() : void
	~ internalMethod() : void
}

note right of Pit
	Recommended usage:
	keep one long-lived `Pit`
	instance in memory per
	feature or service and
	use `Save()` as the
	explicit persistence
	and sync boundary.
end note

note bottom of JsonPitBase
	JsonPit's server-side model
	is best described as
	asynchronous persistence
	with eventual durability.
end note

@enduml
